# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
# Test playbook (personas, fixtures, registry, external references) is tracked.
# Only the ephemeral run outputs are gitignored.
/test/results/

# External reference dump provided for 2026-04 R4/async-research planning — not
# intended for public repo. The smaller, curated test/external-references/zansei/
# bundle IS tracked for in-repo provenance.
/relevant-zansei-materials/

# Playwright / future E2E artifacts (if added)
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep `.env.example` committed as the key template
.env*
!.env.example

# Cursor IDE
.cursor/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
