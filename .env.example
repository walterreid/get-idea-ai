NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=getidea-orchestrator

# Web research (Phase 5 / R1). Serper = Google search API; Jina Reader = URL → clean text.
# https://serper.dev — https://jina.ai/reader
SERPER_API_KEY=
JINA_API_KEY=

# Legacy: only needed if not yet migrated to Serper+Jina (remove after R1 cutover)
TAVILY_API_KEY=

# ── Admin / Dev Auth (Phase 8.1, local only) ─────────────────────
# ADMIN_EMAIL is the owner account. In production, this user signs
# in via magic link like any other user — nothing special.
#
# DEV_USER_PASSWORD enables the /dev/login route for local testing.
# The route is double-guarded: it returns 404 unless NODE_ENV=development
# AND both env vars below are set.
#
# Setup: leave DEV_USER_PASSWORD empty and run `npm run admin:init` —
# the script generates a strong password, prints it once, and sets it on
# the Supabase user. Paste that value in below. Or supply your own before
# running the script. Either way, .env.local is gitignored, so the
# password never enters the repo.
ADMIN_EMAIL=walterreid@gmail.com
DEV_USER_PASSWORD=

# NEXT_PUBLIC_SITE_URL is used by /dev/login to build the redirect URL.
# Defaults to http://localhost:3000 if unset. Override for non-standard
# dev ports or alternative staging URLs.
NEXT_PUBLIC_SITE_URL=

ADMIN_EMAIL=
DEV_USER_PASSWORD=your-password-here